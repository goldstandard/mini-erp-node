# Local development environment template
# Copy to .env (do not commit .env)

# --- App ---
NODE_ENV=development
# Optional local DB override (relative to project root or absolute path)
# DB_PATH=data/mini_erp.db

# --- Auth ---
# JWT_SECRET=replace-with-long-random-secret

# --- SMTP transport (canonical names) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Optional: true/false, defaults by port (465 => true)
SMTP_SECURE=false
SMTP_FROM_EMAIL=
APPROVAL_FROM_EMAIL=

# --- SMTP aliases (supported) ---
# MAIL_HOST=
# MAIL_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# --- Notification recipients ---
REMINDER_FROM_EMAIL=
REMINDER_TO_EMAIL=
RECIPE_SUBMISSION_NOTIFY_TO=
RECIPE_APPROVAL_NOTIFY_TO=
APPROVAL_NOTIFY_TO=
